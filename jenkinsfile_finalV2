pipeline {
  agent any
  environment {
        NAME = 'MARLIN'
        LASTNAME = 'SOFT'
        PATH2 = '/root/SRINI/webproject.yml'
        CMD2 = 'ansible-playbook'
        }

  tools {
       maven 'Maven 3.9'
      }
  stages {
    stage ('Build') {
          steps{
                sh 'echo $NAME $LASTNAME'
                sh script: 'mvn clean package'
                }
          }
    stage('Test') {
          steps {
                  sh 'echo "Accessed global vars in stage2 as well ... "'
                  sh 'echo $NAME $LASTNAME'
                }

           }
  stage('Deploy') {
          steps {
                  sh 'echo "Continuos deploying .."'
                  sh '''
                  sudo su - root -c "$CMD2 $PATH2"
                  '''
                  }

           }
        }
   }
 
